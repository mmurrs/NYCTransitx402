# ─── MPP (Tempo USDC) ─────────────────────────────────────────────────
# HMAC key used by mppx to sign/verify challenges. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MPP_SECRET_KEY=

# Tempo USDC token contract address
#   Mainnet (chain 4217):  0x20C068fa8e3b47B2A6f46c3b40b9537d11c60E8b50
#   Testnet (chain 42431): 0x20c0000000000000000000000000000000000000
USDC_TEMPO=

# MPP payment recipient (falls back to RECIPIENT_WALLET).
MPP_RECIPIENT=

# Optional hostname to advertise in MPP `WWW-Authenticate` challenges.
# Set this when auto-detection picks an internal container/app hostname
# instead of your public domain. Example: transit402.dev
MPP_REALM=

# Set to "true" to use Tempo testnet instead of mainnet.
MPP_TESTNET=false

# ─── x402 (Base USDC) ─────────────────────────────────────────────────
# x402 payment recipient on Base (falls back to RECIPIENT_WALLET).
X402_PAYEE_ADDRESS=

# CAIP-2 chain ID:
#   eip155:8453   Base mainnet (default)
#   eip155:84532  Base Sepolia
X402_NETWORK=eip155:8453

# Facilitator /verify + /settle endpoint:
#   Mainnet:  https://api.cdp.coinbase.com/platform/v2/x402
#   Testnet:  https://x402.org/facilitator
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# Coinbase Developer Platform API credentials. REQUIRED when using the
# CDP hosted facilitator (api.cdp.coinbase.com) for x402 on Base mainnet.
# Not needed when pointing X402_FACILITATOR_URL at x402.org/facilitator
# or a self-hosted facilitator.
#   1. Create an API key at https://portal.cdp.coinbase.com/
#   2. Ed25519 is preferred; EC (ES256) also works.
#   3. The ID is a UUID (or an organizations/.../apiKeys/... path).
#   4. The SECRET is either a base64 Ed25519 key (one line) or a PEM
#      block. For PEM, use \n to encode newlines in .env, e.g.
#      CDP_API_KEY_SECRET="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----\n"
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ─── Shared recipient (convenience) ───────────────────────────────────
# Used as the default for BOTH MPP_RECIPIENT and X402_PAYEE_ADDRESS if
# those are unset. Per-network overrides above take precedence.
RECIPIENT_WALLET=

# ─── Optional ─────────────────────────────────────────────────────────
# Public URL the service is reachable at. Used to build resource URLs
# in x402 challenges and /.well-known/x402 discovery. Set this when
# running behind a proxy/CDN so clients don't see the origin hostname.
#   e.g. https://transit402.dev
BASE_URL=

# MTA bus SIRI API key (get one at https://api.mta.info).
# Without this, /bus/nearest returns 503 "Bus predictions unavailable".
MTA_BUS_API_KEY=

PORT=8080
