# Payment — MPP
MPP_SECRET_KEY=           # 64-char hex HMAC key (generate: openssl rand -hex 32)
USDC_TEMPO=               # USDC token address for MPP settlement
MPP_RECIPIENT=            # Wallet address to receive MPP payments
MPP_TESTNET=false         # Set to "true" for testnet

# Payment — x402
X402_PAYEE_ADDRESS=       # Wallet address to receive x402 payments (Base)
X402_NETWORK=eip155:84532 # eip155:84532 (Base Sepolia) or eip155:8453 (Base mainnet)
X402_FACILITATOR_URL=https://x402.org/facilitator  # Testnet facilitator

# Shared
RECIPIENT_WALLET=         # Fallback recipient for both protocols (if per-protocol not set)

# Data sources
MTA_BUS_API_KEY=          # MTA Bus Time API key (https://api.mta.info)

# Optional
BASE_URL=                 # Override base URL in payment challenges (behind proxy)
PORT=8080                 # Server port
